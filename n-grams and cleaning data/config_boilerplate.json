{
  "description": "UN Document Boilerplate Text Cleaning Configuration",
  "version": "2.1",
  "boilerplate_patterns": {
    "formatting_artifacts": {
      "enabled": true,
      "description": "Formatting artifacts, repeated punctuation, and OCR errors",
      "patterns": [
        "(?:\\.\\s+){3,}\\.",
        "(?:–\\s+){3,}–",
        "(?:•\\s+){3,}•",
        "(?:—\\s+){3,}—",
        "(?:-\\s+){3,}-",
        "(?:\\d\\s+){3,}\\d",
        "(?:[a-z]\\s+){4,}[a-z]\\s+[a-z]",
        "(?:and,\\s+){3,}and,?"
      ]
    },
    "administrative_metadata": {
      "enabled": true,
      "description": "Administrative status markers, audit language, and financial table headers",
      "patterns": [
        "(?i)status:\\s*in\\s+progress\\s+priority:\\s*(?:high|medium|low)\\s+target\\s+date:.*?(?:quarter|\\d{4})",
        "(?i)(?:agreed|disagrees?)\\s+with\\s+the\\s+board[''']?s\\s+recommendation\\s+that.*?(?=\\.|\\n)",
        "(?i)expenditure\\s+appropriation\\s+adjustments\\s+mandates\\s+other\\s+total\\s+percentage\\s+recosting\\)?",
        "(?i)as\\s+at\\s+\\d{1,2}\\s+(?:january|february|march|april|may|june|july|august|september|october|november|december)\\s+\\d{4}\\s*\\(thousands\\s+of\\s+united\\s+states\\s+dollars\\)",
        "(?i)statement\\s+of\\s+income\\s+and\\s+expenditure\\s+and\\s+changes\\s+in\\s+reserves\\s+and\\s+fund\\s+balances",
        "(?i)\\(thousands\\s+of\\s+united\\s+states\\s+dollars\\)",
        "(?i)financial\\s+resources\\s+by\\s+main\\s+category\\s+of\\s+expenditure",
        "(?i)(?:before\\s+)?expenditure\\s+appropriation\\s+adjustments"
      ]
    },
    "procedural_references": {
      "enabled": true,
      "description": "Committee citations, report attributions, and official records",
      "patterns": [
        "(?i)(?:the\\s+)?advisory\\s+committee\\s+on\\s+administrative\\s+and\\s+budgetary\\s+(?:questions|matters)",
        "(?i)report\\s+of\\s+the\\s+secretary-general\\s+on\\s+the\\s+work\\s+of\\s+the\\s+organization",
        "(?i)official\\s+records\\s+of\\s+the\\s+(?:general\\s+assembly|economic\\s+and\\s+social\\s+council),?\\s*(?:thirty-first|thirty-second|thirty-third|[a-z\\-]+)?\\s*(?:session)?",
        "(?i)by\\s+the\\s+general\\s+assembly\\s+in\\s+its\\s+resolution\\s*(?:\\d+)?",
        "(?i)upon\\s+enquiry,\\s+the\\s+advisory\\s+committee\\s+was\\s+informed\\s+that",
        "(?i)for\\s+the\\s+biennium\\s+ended\\s+\\d{1,2}\\s+(?:january|february|march|april|may|june|july|august|september|october|november|december)\\s+\\d{4}",
        "(?i)records\\s+of\\s+the\\s+general\\s+assembly,\\s*(?:thirty-first|thirty-second|[a-z\\-]+)?\\s*session",
        "(?i)progress\\s+towards\\s+the\\s+attainment\\s+of\\s+the\\s+objective,\\s+and\\s+performance\\s+measure"
      ]
    },
    "standard_entity_names": {
      "enabled": false,
      "description": "Long-form standard entity names (disabled by default - may remove substantive content)",
      "patterns": [
        "(?i)united\\s+kingdom\\s+of\\s+great\\s+britain\\s+and\\s+northern\\s+ireland",
        "(?i)economic\\s+and\\s+social\\s+development\\s+in\\s+latin\\s+america\\s+and\\s+the\\s+caribbean",
        "(?i)office\\s+of\\s+the\\s+united\\s+nations\\s+high\\s+commissioner\\s+for\\s+(?:refugees|human\\s+rights)",
        "(?i)least\\s+developed\\s+countries,\\s+landlocked\\s+developing\\s+countries\\s+and\\s+small\\s+island\\s+developing",
        "(?i)department\\s+of\\s+(?:peacekeeping\\s+operations|economic\\s+and\\s+social\\s+affairs)",
        "(?i)general\\s+assembly\\s+and\\s+economic\\s+and\\s+social\\s+council\\s+affairs\\s+and\\s+conference\\s+management",
        "(?i)office\\s+for\\s+the\\s+coordination\\s+of\\s+humanitarian\\s+affairs"
      ]
    },
    "opening_ceremonials": {
      "enabled": false,
      "description": "DISABLED: 'On behalf of' and 'congratulate' appear in substantive speech content too frequently. These patterns were removing real policy text.",
      "patterns": [
        "(?:On behalf of the General Assembly|I have the honour to welcome)[^.!?]{0,250}[.!?]",
        "(?:Allow me|I would like to|We would like to)\\s+(?:at the outset|at the beginning)\\s+to[^.!?]{0,250}congratulate[^.!?]{0,150}[.!?]",
        "I would like to congratulate[^.!?]{0,250}[.!?]"
      ]
    },
    "procedural_markers": {
      "enabled": true,
      "description": "Chair/President procedural statements (single line only)",
      "patterns": [
        "(?:The\\s+)?(?:President|Chair|Chairperson):\\s+[^\\n]{0,300}(?=\\n)",
        "(?:The President|The Chair):\\s+[^\\n]{0,300}(?=\\n)"
      ]
    },
    "gratitude_sections": {
      "enabled": false,
      "description": "DISABLED: 'Thank you for the...' and 'I would like to thank...' appear in substantive speech too frequently. These patterns were removing real content.",
      "patterns": [
        "I would like to thank[^.!?]{0,200}Secretary-General[^.!?]{0,150}[.!?]",
        "I would also like to (?:congratulate|thank)[^.!?]{0,250}[.!?]",
        "Thank you[^.!?]{0,100}(?:for your|for the)[^.!?]{0,150}[.!?]"
      ]
    },
    "document_references": {
      "enabled": true,
      "description": "UN document reference citations",
      "patterns": [
        "\\((?:A|S|E)/[A-Z0-9/\\.]+\\)",
        "\\(see\\s+(?:A|S|E)/[A-Z0-9/\\.]+\\)",
        "\\[.*?document.*?\\]",
        "\\(\\s*para(?:graph|\\.)?s?\\.?\\s*\\d+(?:\\s*(?:and|to|\\-|,)\\s*\\d+)*\\s*(?:above|below|thereof)?\\s*\\)"
      ]
    },
    "speaker_attribution_lines": {
      "enabled": true,
      "description": "Speaker identification headers before speech text, e.g. 'Mr. Smith (France):'",
      "patterns": [
        "^\\s*(?:Mr\\.|Mrs\\.|Ms\\.|Dr\\.|Prof\\.|His\\s+Excellency|Her\\s+Excellency|The\\s+(?:President|Chair(?:person)?|Secretary(?:-General)?|Rapporteur|Observer|Representative))\\s+[A-Z][A-Za-z\\-']{1,30}(?:\\s+[A-Z][A-Za-z\\-']{1,30}){0,4}\\s*(?:\\([^)]{2,60}\\))?\\s*:\\s*$",
        "^\\s*(?:The\\s+)?(?:PRESIDENT|CHAIR|CHAIRPERSON|VICE-PRESIDENT|SECRETARY-GENERAL|RAPPORTEUR|REPRESENTATIVE|OBSERVER)(?:\\s+\\([^)]{2,60}\\))?\\s*:\\s*$"
      ]
    },
    "document_bracket_refs": {
      "enabled": true,
      "description": "Bracket-style UN document reference codes like [A/C.1/69/PV.13]",
      "patterns": [
        "\\[(?:A|S|E|C|ST|DP)(?:\\/[A-Z0-9\\.\\-]+){1,6}\\]",
        "\\b(?:A|S|E|C)\\/(?:RES|DEC|INF|AC|C|CONF|HRC|CN)\\.?\\s*\\d+[A-Z]?(?:\\/[A-Z0-9\\.]+){0,4}\\b"
      ]
    },
    "cross_reference_parentheticals": {
      "enabled": true,
      "description": "Inline cross-references and language attribution parentheticals",
      "patterns": [
        "\\(\\s*see\\s+(?:para(?:graph|\\.)?s?\\.?|ann?ex(?:es)?|appendix|figure|table|section|chapter)\\s+[A-Z0-9][A-Za-z0-9\\.\\-\\s]{0,30}\\)",
        "\\(\\s*see\\s+(?:above|below)\\s*\\)",
        "\\(\\s*(?:ibid|id\\.|op\\.\\s*cit\\.|loc\\.\\s*cit\\.)\\s*(?:,\\s*[^)]{0,30})?\\)",
        "\\(\\s*(?:spoke|speaking|statement|intervention)\\s+(?:in|was\\s+(?:made|delivered)\\s+in)\\s+(?:English|French|Spanish|Arabic|Russian|Chinese)\\s*(?:;[^)]{0,30})?\\)",
        "\\(\\s*(?:The\\s+)?(?:original|text)\\s+(?:was\\s+)?(?:in|is)\\s+(?:English|French|Spanish|Arabic|Russian|Chinese)\\s*\\)",
        "\\(\\s*(?:translation|interpreted|interpretation)\\s+(?:from|by)[^)]{0,60}\\)"
      ]
    },
    "allcaps_document_headers": {
      "enabled": false,
      "description": "All-caps single-line document headers (disabled - validate on sample before enabling)",
      "patterns": [
        "^\\s*[A-Z][A-Z\\s\\-\\/\\.]{4,60}[A-Z]\\s*$",
        "^\\s*(?:ANNEX|APPENDIX|SCHEDULE|ADDENDUM|CORRIGENDUM)\\s+[IVX\\d]+[\\s\\S]{0,80}?$"
      ]
    },
    "closing_statements": {
      "enabled": false,
      "description": "DISABLED: 'In conclusion' often introduces substantive concluding arguments, not boilerplate.",
      "patterns": [
        "In conclusion,[^.!?]{0,300}[.!?]",
        "(?:Confidence and hope|All of us, as in a marriage)[^.!?]{0,300}[.!?]",
        "The world's problems could be solved peacefully[^.!?]{0,300}[.!?]"
      ]
    },
    "ceremonial_phrases": {
      "enabled": true,
      "description": "Ceremonial opening and closing language",
      "patterns": [
        "\\*+[^*]{0,200}\\*+",
        "\\n\\s+[^\\n]{0,200}\\(spoke in (?:English|French|Spanish|Arabic)\\)[^\\n]{0,100}\\n",
        "Address/Statement recorded in .*?\\)"
      ]
    }
  },
  "text_cleaning": {
    "remove_extra_whitespace": true,
    "remove_parenthetical_attributions": true,
    "description": "Additional text cleaning options"
  },
  "output_options": {
    "preserve_structure": false,
    "min_paragraph_length": 50,
    "description": "Only keep paragraphs with meaningful content (>50 chars)"
  }
}
